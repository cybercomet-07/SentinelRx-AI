APP_NAME=SentinelRx-AI Backend
APP_ENV=production

API_V1_PREFIX=/api/v1

# Database (required) - Use Neon/Supabase/Railway connection string in production
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/sentinelrx

# Auth (required - use a long random string in production)
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS - Add your Vercel frontend URL here (comma-separated)
CORS_ORIGINS=http://localhost:3005,https://your-app.vercel.app

# AI keys
GROQ_API_KEY=
COHERE_API_KEY=
DEEPSEEK_API_KEY=

# Brevo - order confirmation email + invoice PDF
BREVO_API_KEY=

# Cloudinary - image uploads (payment receipts, prescriptions)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
